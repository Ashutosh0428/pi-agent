# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# pi reads keys from the environment only — they are never stored or logged.
# Set only the provider(s) you use.

# Paid
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Free tiers (no credit card) — https://console.groq.com/keys ,
# https://openrouter.ai/keys , https://aistudio.google.com/apikey
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Ollama (local, no key) needs no variable — just run `ollama serve`.

# Optional overrides
# PI_AGENT_MODEL=claude-sonnet-4-6
# PI_AGENT_MAX_TOKENS=4096
# PI_AGENT_MAX_ITERS=25
